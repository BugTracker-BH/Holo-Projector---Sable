{
  "type": "minecraft:multi_action",
  "title": {"text": "HELIX OS - SABLE Containment", "color": "dark_green", "bold": true},
  "body": [
    {
      "type": "minecraft:plain_message",
      "contents": {"text": "HELIX OS v2.7.1 | Threat: CRITICAL | SABLE: CONTAINED", "color": "red"}
    },
    {
      "type": "minecraft:plain_message",
      "contents": {"text": "Nav: ls lsa cd pwd tree find grep stat", "color": "gray"}
    },
    {
      "type": "minecraft:plain_message",
      "contents": {"text": "Files: cat hexdump run | Sys: ps top kill df uname uptime", "color": "gray"}
    },
    {
      "type": "minecraft:plain_message",
      "contents": {"text": "CTF: unlock <key> | Net: ping ssh curl (SEVERED)", "color": "dark_gray"}
    }
  ],
  "inputs": [
    {
      "type": "minecraft:text",
      "key": "cmd",
      "label": {"text": "Command"},
      "width": 140,
      "max_length": 32
    },
    {
      "type": "minecraft:text",
      "key": "arg",
      "label": {"text": "Argument (path, key, pattern...)"},
      "width": 300,
      "max_length": 256
    }
  ],
  "columns": 1,
  "actions": [
    {
      "label": {"text": "Execute", "color": "green", "bold": true},
      "action": {
        "type": "minecraft:dynamic/run_command",
        "template": "function helix:shell/exec_from_dialog {cmd:\"$(cmd)\",arg:\"$(arg)\"}"
      }
    },
    {
      "label": {"text": "Help", "color": "yellow"},
      "action": {
        "type": "minecraft:run_command",
        "command": "function helix:shell/cmd/help"
      }
    },
    {
      "label": {"text": "Clear", "color": "aqua"},
      "action": {
        "type": "minecraft:run_command",
        "command": "function helix:shell/cmd/clear"
      }
    },
    {
      "label": {"text": "Close", "color": "gray"},
      "action": {
        "type": "minecraft:run_command",
        "command": "dialog clear @s"
      }
    }
  ]
}
